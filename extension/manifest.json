{
  "manifest_version": 3,
  "name": "LEGO Rangement — Rebrickable Sync",
  "version": "2.0.0",
  "description": "Synchronise les emplacements d’une part list Rebrickable avec l’application LEGO Rangement locale.",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://rebrickable.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://rebrickable.com/users/*/partlists/*", "https://rebrickable.com/sets/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["app-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
